#!/bin/bash
# Connectivity test for ntfy Push Notifications
# This script verifies the gateway can successfully publish to ntfy

set -e

# Use environment variables provided by the test executor
TEST_MESSAGE="unitysvc connectivity test successful"

# Publish a test message to the enrollment's ntfy topic
# SERVICE_BASE_URL already contains the complete URL with generated topic code
response=$(curl -s -X POST \
  "{{ service_base_url }}" \
  -H "Content-Type: text/plain" \
  -H "Authorization: Bearer ${UNITYSVC_API_KEY}" \
  -d "${TEST_MESSAGE}")

# Check if the response contains expected ntfy event type
if echo "$response" | grep -q '"event":"message"'; then
  echo "unitysvc connectivity test successful"
  echo "Response: $response"
  exit 0
else
  echo "Connectivity test failed"
  echo "Response: $response"
  exit 1
fi
